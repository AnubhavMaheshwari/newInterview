## Client environment variables (Vite)
#
# In production (Vercel), set this to your deployed BACKEND base URL, e.g.
# VITE_BACKEND_URL=https://your-backend.vercel.app
#
# In local dev you can leave it blank because the Vite dev server proxies `/api/*` and `/auth/*` to the backend.
VITE_BACKEND_URL=

# Backend API Configuration
REACT_APP_BACKEND_URL=http://localhost:3000
